              "try { pm.cookies.jar().clear(base, function () {}); } catch (e) { console.log('jar clear:', e.message); }"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 401 con password incorrecto', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            { "key": "username", "value": "{{user}}", "type": "string" },
            { "key": "password", "value": "password-incorrecto", "type": "string" }
          ]
        },
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"no-deberia-crearse\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/wikis/{{wiki}}/spaces/{{space}}/pages/{{page}}/comments",
          "host": [ "{{baseUrl}}" ],
          "path": [ "rest", "wikis", "{{wiki}}", "spaces", "{{space}}", "pages", "{{page}}", "comments" ]
        }
      }
    }
  ],
