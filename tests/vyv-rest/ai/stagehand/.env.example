# ==============================================================
# GROQ — LLM gratis en la nube (recomendado)
# Obtener key en https://console.groq.com/
# ==============================================================
GROQ_API_KEY=gsk_PEGA_TU_KEY_AQUI
GROQ_MODEL=llama-3.3-70b-versatile

# ==============================================================
# Configuracion general (XWiki)
# ==============================================================
HEADLESS=false
BASE_URL=http://localhost:8080
XWIKI_USER=emmanuel_calad
XWIKI_PASS=TU_PASSWORD
# Pagina DEDICADA y minima para las pruebas (se crea/borra por API).
# Mantenerla pequena evita el limite de tokens del LLM (no usar Main.WebHome,
# que acumula muchos comentarios y hace el DOM demasiado grande).
ESPACIO=ComentariosIA
PAGINA=PruebaStagehand
