# ==============================================================
# OLLAMA LOCAL — modelo JUEZ de DeepEval (gratis, sin rate limits)
# Requiere Ollama corriendo y el modelo descargado:
#   ollama pull llama3.2
# ==============================================================
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# ==============================================================
# Path al archivo de resultados de Stagehand que vamos a evaluar
# (lo genera el flujo TS: cd ../stagehand && npm run stagehand:eval)
# ==============================================================
STAGEHAND_RESULTS_PATH=./data/stagehand-results.json
