// ============================================================
// Jenkinsfile - Pipeline V&V para las pruebas REST de XWiki
// Mismos pasos que CocinaCompartida, adaptados a Java/Maven.
//
// OJO: la rama master es 18.5.0-SNAPSHOT y NO compila. Por eso el pipeline
// usa un worktree del release 18.4.0 (que SI compila) para correr las pruebas
// contra el codigo real + cobertura JaCoCo + SonarQube, y al final despliega
// el XWiki de docker-compose.
//
// Configurar el Job de Jenkins con: Pipeline script from SCM -> Script Path:
//   tests/vyv-rest/Jenkinsfile
// ============================================================
pipeline {
    agent any

    // El contenedor jenkins/jenkins:lts ya trae Java 21, asi que NO configuramos jdk.
    // Solo Maven (ajusta el nombre al de Jenkins > Global Tool Configuration).
    tools {
        maven 'Maven-3.9'
    }

    environment {
        XWIKI_TAG      = 'xwiki-platform-18.4.0'
        // Reusar el MISMO proyecto/volumenes de XWiki en Deploy (no borrar el flavor instalado)
        COMPOSE_PROJECT_NAME = 'xwiki-platform'
        WORKTREE       = "${WORKSPACE}/../xwiki-184"
        MODULE         = "${WORKSPACE}/../xwiki-184/xwiki-platform-core/xwiki-platform-rest/xwiki-platform-rest-server"
        XWIKI_SETTINGS = "${WORKSPACE}/tests/vyv-rest/settings-xwiki.xml"
        TESTS_SRC      = "${WORKSPACE}/tests/vyv-rest/proyecto-modulo-real/src/test/java"
        MAIN_SRC       = "${WORKSPACE}/tests/vyv-rest/proyecto-modulo-real/src/main/java"
        // Solo estas clases cuentan en la cobertura (sync con correr.ps1 $teamInclusions)
        SONAR_INCLUSIONS = '**/comments/Comment*Impl.java,**/objects/ObjectResourceImpl.java,**/pages/PageTagsResourceImpl.java'
        MAVEN_OPTS = '-Xmx2g'
    }

    options {
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    stages {

        stage('Verify Environment') {
            steps {
                echo 'Verificando entorno...'
                sh '''
                    echo "=== Workspace ==="
                    ls -la
                    echo "=== Java ==="
                    java -version
                    echo "=== Maven ==="
                    mvn -version
                    echo "=== Git ==="
                    git --version
                '''
            }
        }

        stage('Setup Worktree (release 18.4.0)') {
            steps {
                echo 'Preparando worktree del release que SI compila'
                sh '''
                    set -e
                    # Bajar el tag release si falta (master es SNAPSHOT, no resoluble)
                    if ! git tag --list "$XWIKI_TAG" | grep -q "$XWIKI_TAG"; then
                      git fetch --depth 1 https://github.com/xwiki/xwiki-platform.git "refs/tags/${XWIKI_TAG}:refs/tags/${XWIKI_TAG}"
                    fi
                    # Worktree limpio
                    git worktree remove --force "$WORKTREE" 2>/dev/null || true
                    git worktree prune
                    # Borrar como root via docker (los builds dejan archivos root-owned que jenkins no puede rm)
                    docker exec -u 0 jenkins rm -rf "$WORKTREE" 2>/dev/null || rm -rf "$WORKTREE" || true
                    git worktree add -f "$WORKTREE" "$XWIKI_TAG"
                '''
            }
        }

        stage('Sync Tests') {
            steps {
                echo 'Copiando los tests del equipo al modulo real del worktree'
                sh '''
                    mkdir -p "$MODULE/src/test/java"
                    cp -r "$TESTS_SRC/." "$MODULE/src/test/java/"
                    # Sincronizar tambien el codigo de produccion modificado por el equipo
                    # (sobre-escribe el original de XWiki en el worktree, p.ej. CommentsResourceImpl con validacion 400).
                    if [ -d "$MAIN_SRC" ]; then
                      mkdir -p "$MODULE/src/main/java"
                      cp -r "$MAIN_SRC/." "$MODULE/src/main/java/"
                      echo "=== main (produccion) sincronizado ==="
                    fi
                    echo "=== tests sincronizados ==="
                    find "$MODULE/src/test/java/org/xwiki/rest/internal/resources" -name "*Test.java" | sed "s|.*/resources/||" | sort
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                echo 'Pruebas unitarias contra el codigo real de XWiki + cobertura JaCoCo'
                dir("${MODULE}") {
                    sh '''
                        mvn -s "$XWIKI_SETTINGS" clean \
                            org.jacoco:jacoco-maven-plugin:0.8.12:prepare-agent \
                            test \
                            org.jacoco:jacoco-maven-plugin:0.8.12:report
                    '''
                }
            }
            post {
                always {
                    junit testResults: "**/xwiki-184/**/surefire-reports/*.xml", allowEmptyResults: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo 'SonarQube analysis (solo clases del equipo)'
                dir("${MODULE}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn -s "$XWIKI_SETTINGS" \
                                org.sonarsource.scanner.maven:sonar-maven-plugin:sonar \
                                -Dsonar.projectKey=Xwiki \
                                -Dsonar.projectName=Xwiki \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                                -Dsonar.inclusions="$SONAR_INCLUSIONS" \
                                -Dsonar.test.exclusions="**/attachments/**" \
                                -Dsonar.sourceEncoding=UTF-8
                        '''
                    }
                    timeout(time: 5, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: false
                    }
                }
            }
        }

        stage('Pull Docker Images') {
            steps {
                echo 'Bajando imagenes Docker (XWiki usa imagen prearmada, no se construye)'
                sh '''
                    if docker compose version >/dev/null 2>&1; then
                      docker compose pull
                    elif command -v docker-compose >/dev/null 2>&1; then
                      docker-compose pull
                    else
                      echo 'docker compose / docker-compose no disponible'
                      exit 1
                    fi
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo 'Desplegando XWiki con docker compose'
                sh '''
                    if docker compose version >/dev/null 2>&1; then
                      docker compose down || true
                      docker compose up -d
                      docker compose ps
                    elif command -v docker-compose >/dev/null 2>&1; then
                      docker-compose down || true
                      docker-compose up -d
                      docker-compose ps
                    else
                      echo 'docker compose / docker-compose no disponible'
                      exit 1
                    fi
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline finalizado'
            archiveArtifacts artifacts: '**/xwiki-184/**/target/site/jacoco/**, **/xwiki-184/**/surefire-reports/**', allowEmptyArchive: true
        }
        success {
            echo 'Pipeline exitoso'
        }
        failure {
            echo 'Pipeline fallo - revisar logs'
        }
    }
}
